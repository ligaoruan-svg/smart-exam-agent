# ============================================================
# 公考小智 v2 - 环境变量配置
# 复制此文件为 .env 后修改：cp .env.example .env
# ============================================================

# ---------- 数据库 ----------
DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=

# ---------- DeepSeek LLM ----------
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=

# ---------- JWT ----------
# 生产环境必须改！可以用：python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=gk-
JWT_EXPIRES_HOURS=

# ---------- MCP Server ----------
# FastAPI 通过此 URL 连接 MCP server
MCP_URL=http://localhost:8765/sse
# MCP server 自身监听端口（启动 SSE 模式时用）
MCP_PORT=8765

# ---------- FastAPI ----------
API_HOST=0.0.0.0
API_PORT=8900
API_BASE=http://localhost:8900

# ---------- 日志 ----------
# DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
LOG_DIR=./logs

# ---------- 前端开发 ----------
# Vite 在 vite.config.js 里硬编码读这个
VITE_API_BASE=http://localhost:8900


QQ验证
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
